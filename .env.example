# Database
POSTGRES_DB=siteguard
POSTGRES_USER=siteguard
POSTGRES_PASSWORD=change_me_strong_password
DATABASE_URL=postgresql://siteguard:change_me_strong_password@postgres:5432/siteguard

# Redis
REDIS_URL=redis://redis:6379/0

# Backend
SECRET_KEY=change_me_to_long_random_string
# CORS: список через запятую, без слэша на конце
ALLOWED_ORIGINS=http://localhost:3001,http://YOUR_SERVER_IP:3001

# Frontend (URL backend, который будет вызывать браузер)
NEXT_PUBLIC_API_URL=http://YOUR_SERVER_IP:8001

# Rate limiting (requests per minute per IP)
RATE_LIMIT_PER_MINUTE=10

# Scanner
SCANNER_MAX_PAGES=10
SCANNER_TIMEOUT=15
